<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/overlay_background"
    android:padding="32dp">

    <!-- Big warning text -->
    <TextView
        android:id="@+id/tv_drive_safe"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="80dp"
        android:text="@string/drive_safe"
        android:textColor="@color/white"
        android:textSize="42sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tv_overlay_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/tv_drive_safe"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="8dp"
        android:text="@string/overlay_subtitle"
        android:textColor="@color/text_secondary_light"
        android:textSize="16sp" />

    <!-- Speed display -->
    <TextView
        android:id="@+id/tv_overlay_speed"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:text="0 mph"
        android:textColor="@color/white"
        android:textSize="72sp"
        android:textStyle="bold" />

    <!-- Maps button -the only allowed action -->
    <Button
        android:id="@+id/btn_open_maps"
        android:layout_width="200dp"
        android:layout_height="56dp"
        android:layout_above="@id/btn_emergency_unlock"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="24dp"
        android:text="@string/open_maps"
        android:textSize="18sp"
        android:textColor="@color/white"
        android:background="@color/maps_button" />

    <!-- Emergency unlock (hold 3 sec) -->
    <TextView
        android:id="@+id/btn_emergency_unlock"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="40dp"
        android:text="@string/emergency_unlock"
        android:textColor="@color/text_secondary_light"
        android:textSize="12sp"
        android:padding="16dp" />

</RelativeLayout>
